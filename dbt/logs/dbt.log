        struct('BA', 'BH'),
        struct('QA', 'QA'),
        struct('TC', 'AE'),
        struct('YM', 'YE'),
        struct('OM', 'OM')
    ] as t)

),

ranked as (

    select
        b.*,
        coalesce(f.iso, b.action_geo_country_code)          as iso_country_code,
        row_number() over (order by event_count desc)       as country_rank
    from by_country b
    left join fips_to_iso f on b.action_geo_country_code = f.fips

)

select * from ranked
order by country_rank
    );
  

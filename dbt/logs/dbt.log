        struct('CE', 'LK'),
        struct('NP', 'NP'),
        struct('BM', 'MM'),
        struct('CB', 'KH'),
        struct('LA', 'LA'),
        struct('KZ', 'KZ'),
        struct('UZ', 'UZ'),
        struct('AJ', 'AZ'),
        struct('GG', 'GE'),
        struct('AM', 'AM'),
